# Root development helper.
# Backend and frontend read their own env files:
# - backend/.env
# - frontend/.env

# Backend
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/operations_dashboard
CORS_ORIGIN=http://localhost:5173
ADMIN_UPLOAD_KEY=change-me
NODE_ENV=development
DATABASE_SSL=false

# Frontend
VITE_API_BASE_URL=http://localhost:4000
